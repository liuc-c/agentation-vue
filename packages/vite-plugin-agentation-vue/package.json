{
  "name": "vite-plugin-agentation-vue",
  "version": "0.0.5",
  "description": "Vite plugin: one-line setup for agentation-vue (runtime injection + Vue source resolver)",
  "license": "PolyForm-Shield-1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liuc-c/agentation-vue.git",
    "directory": "packages/vite-plugin-agentation-vue"
  },
  "homepage": "https://github.com/liuc-c/agentation-vue/tree/main/packages/vite-plugin-agentation-vue#readme",
  "bugs": {
    "url": "https://github.com/liuc-c/agentation-vue/issues"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./client": {
        "types": "./src/client.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "src/client.d.ts",
    "src/runtime/"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@liuovo/agentation-vue-core": "workspace:*",
    "@liuovo/agentation-vue-ui": "workspace:*",
    "vite-plugin-vue-tracer": "^1.2.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0",
    "vue": "^3.5.0"
  }
}
