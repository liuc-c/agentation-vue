{
  "name": "@liuovo/agentation-vue-ui",
  "version": "0.0.14",
  "description": "Vue 3 UI components: toolbar, overlay, popover, highlight & marker layers",
  "license": "PolyForm-Shield-1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liuc-c/agentation-vue.git",
    "directory": "packages/ui-vue"
  },
  "homepage": "https://github.com/liuc-c/agentation-vue/tree/main/packages/ui-vue#readme",
  "bugs": {
    "url": "https://github.com/liuc-c/agentation-vue/issues"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepack": "pnpm build",
    "test": "vitest run --config vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.96",
    "@iconify-json/vscode-icons": "^1.2.44",
    "@iconify/vue": "^5.0.0",
    "@liuovo/agentation-vue-core": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "lucide-vue-next": "^0.577.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "vite": "^6.4.1"
  }
}
